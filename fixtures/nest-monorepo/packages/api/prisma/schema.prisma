// Prisma schema for the @fixture/api app.
// Exercises: datasource, generator, models, relations, enum, @@map.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
}

model User {
  id    String  @id @default(uuid())
  email String  @unique
  name  String?
  role  Role    @default(USER)
  posts Post[]

  @@map("users")
}

model Post {
  id       String @id @default(uuid())
  title    String
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([authorId])
}
