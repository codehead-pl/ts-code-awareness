{
  "name": "@codehead-pl/tsca-live-data",
  "version": "0.1.1",
  "type": "module",
  "description": "Optional, config-gated live-data tools. Opens the engine's own read-only DB connection (never boots the target app); SELECT-only guard + caps + timeout. Never mutates the target DB.",
  "author": "Michał Tomczuk",
  "license": "MIT",
  "homepage": "https://github.com/codehead-pl/ts-code-awareness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codehead-pl/ts-code-awareness.git",
    "directory": "packages/live-data"
  },
  "engines": {
    "node": ">=22.5"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@codehead-pl/tsca-core": "workspace:*"
  },
  "optionalDependencies": {
    "pg": "^8.13.1",
    "mysql2": "^3.11.5"
  },
  "devDependencies": {
    "@codehead-pl/tsca-adapter-prisma": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
