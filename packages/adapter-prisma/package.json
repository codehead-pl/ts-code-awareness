{
  "name": "@codehead-pl/tsca-adapter-prisma",
  "version": "0.1.1",
  "type": "module",
  "description": "Prisma adapter: schema.prisma → models/relations/enums, the model↔code access bridge, and static migration reports, contributed as prisma:* fragments.",
  "author": "Michał Tomczuk",
  "license": "MIT",
  "homepage": "https://github.com/codehead-pl/ts-code-awareness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codehead-pl/ts-code-awareness.git",
    "directory": "packages/adapter-prisma"
  },
  "engines": {
    "node": ">=22.5"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
