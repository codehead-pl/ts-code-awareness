{
  "name": "@codehead-pl/tsca-daemon",
  "version": "0.1.2",
  "type": "module",
  "description": "Shared multi-tenant HTTP daemon: routes each session to its project by X-Project-Root, keeps maps warm under an LRU.",
  "author": "Michał Tomczuk",
  "license": "MIT",
  "homepage": "https://github.com/codehead-pl/ts-code-awareness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codehead-pl/ts-code-awareness.git",
    "directory": "packages/daemon"
  },
  "engines": {
    "node": ">=22.5"
  },
  "main": "./dist/index.js",
  "bin": {
    "tsca-daemon": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "start": "node dist/index.js",
    "dev": "tsx --conditions=development src/index.ts"
  },
  "dependencies": {
    "@codehead-pl/tsca-core": "workspace:*",
    "@codehead-pl/tsca-adapter-nest": "workspace:*",
    "@codehead-pl/tsca-adapter-prisma": "workspace:*",
    "@codehead-pl/tsca-live-data": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
